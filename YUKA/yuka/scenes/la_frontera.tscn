[node name="DonCarmelo" parent="." instance=ExtResource("5_npc")]
position = Vector2(440, 420)
npc_name = "Don Carmelo"
npc_role = "Agricultor desplazado"
dialogue_lines = Array[String](["Antes esta tierra daba yuca, plátano, cacao... todo lo que necesitábamos.", "Pero el agua del riego viene del río. Y el río ya no es el mismo.", "El mercurio de las dragas lo envenenó todo. Mis cultivos se pudrieron de raíz.", "Fui al REINFO a denunciar. Me dijeron que los mineros tienen permiso.", "¿Permiso para matarnos de hambre? Eso no es un permiso, es una sentencia.", "Si puedes, documenta esto. Que alguien vea lo que nos quitaron."])
dialogue_id = "don_carmelo_testimonio"
npc_color = Color(0.55, 0.38, 0.2, 1)

[node name="SraLucia" parent="." instance=ExtResource("5_npc")]
position = Vector2(1350, 500)
npc_name = "Señora Lucía"
npc_role = "Madre de familia"
dialogue_lines = Array[String](["Mis hijos se bañaban en el río todos los días. Era cristalino.", "Ahora tienen ronchas en la piel. El doctor dice que es el mercurio.", "No tenemos plata para ir a Puerto Maldonado. Aquí no hay hospital.", "Los mineros pasan con sus camiones llenos de arena. No nos miran.", "¿De qué sirve el oro si nos está matando?"])
dialogue_id = "sra_lucia_testimonio"
npc_color = Color(0.6, 0.42, 0.28, 1)

